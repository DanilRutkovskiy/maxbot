# MAX Messenger
MAX_BOT_TOKEN=your_max_bot_token
MAX_API_URL=https://platform-api.max.ru
MAX_WEBHOOK_SECRET=

# Replicate
REPLICATE_API_TOKEN=r8_your_replicate_token
REPLICATE_MODEL=fofr/live-portrait

# Provider: replicate | fal | liveportrait
ANIMATION_PROVIDER=replicate

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Paths
STORAGE_PATH=./storage
TEMP_PATH=./temp
ASSETS_PATH=./assets

# Defaults
DEFAULT_PRESET=smile
LOG_LEVEL=INFO

# Limits
MAX_IMAGE_BYTES=10485760
DOWNLOAD_TIMEOUT_SEC=30
REPLICATE_POLL_INTERVAL_SEC=2
REPLICATE_POLL_TIMEOUT_SEC=600
VIDEO_MAX_DURATION_SEC=15
VIDEO_MAX_WIDTH=720
GENERATE_GIF_PREVIEW=false
